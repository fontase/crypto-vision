# ═══════════════════════════════════════════════════════════════
# Crypto Vision — Environment Variables
# ═══════════════════════════════════════════════════════════════

# Server
PORT=8080
NODE_ENV=development
LOG_LEVEL=debug

# Redis (GCP Memorystore or local)
REDIS_URL=redis://localhost:6379

# ─── Free APIs (no key required) ─────────────────────────────
# CoinGecko free tier — 30 req/min
# DeFiLlama — unlimited, no key
# CoinPaprika — free tier
# CoinCap — free tier
# DexScreener — free, no key
# Fear & Greed Index — free

# ─── Optional: Higher rate limits ─────────────────────────────
COINGECKO_API_KEY=
COINGECKO_PRO=false
CRYPTOCOMPARE_API_KEY=
NEWSAPI_API_KEY=
CRYPTOPANIC_API_KEY=

# ─── AI / LLM (for AI-powered endpoints) ─────────────────────
GROQ_API_KEY=

# ─── GCP (production) ────────────────────────────────────────
GCP_PROJECT_ID=
GCP_REGION=us-central1
