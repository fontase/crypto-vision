# ─── Development / Staging ────────────────────────────────────
# Copy this file and adjust for your environment:
#   cp terraform.tfvars.example terraform.tfvars

project_id = "your-gcp-project-id"
region     = "us-central1"

# Service
service_name = "crypto-vision"
domain       = "cryptocurrency.cv"

# Redis — use BASIC for dev, STANDARD_HA for prod
redis_tier           = "BASIC"
redis_memory_size_gb = 1

# Cloud Run scaling
cloud_run_memory        = "1Gi"
cloud_run_cpu           = "2"
cloud_run_min_instances = 1
cloud_run_max_instances = 20

# Container image — leave empty to use default gcr.io path
container_image = ""
